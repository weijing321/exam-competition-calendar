{
  "version": 2,
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/competitions/(.*)", "destination": "/api/competitions" },
    { "source": "/api/competitions", "destination": "/api/competitions" },
    { "source": "/api/exams/(.*)", "destination": "/api/exams" },
    { "source": "/api/exams", "destination": "/api/exams" },
    { "source": "/api/notifications/(.*)", "destination": "/api/notifications" },
    { "source": "/api/notifications", "destination": "/api/notifications" },
    { "source": "/api/user/(.*)", "destination": "/api/user" },
    { "source": "/api/user", "destination": "/api/user" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
