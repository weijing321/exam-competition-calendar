{
  "version": 2,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.ts" },
    { "source": "/api/competitions/:path*", "destination": "/api/competitions.ts" },
    { "source": "/api/exams/:path*", "destination": "/api/exams.ts" },
    { "source": "/api/notifications/:path*", "destination": "/api/notifications.ts" },
    { "source": "/api/user/:path*", "destination": "/api/user.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
